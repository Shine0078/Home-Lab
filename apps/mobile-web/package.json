{
  "name": "ad-homelab-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-platform web, iOS, and Android dashboard for AD-HomeLab operations.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "validate:data": "node ./scripts/validate-data.mjs",
    "test": "npm run typecheck && npm run validate:data"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "expo": "~51.0.28",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.12"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
