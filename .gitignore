# Credentials and output
output/

# Ignore all CSV files (may contain credentials)
*.csv

# Exception: allow data files (not credentials)
!data/users.csv
!data/monitored-events.csv

# Logs
logs/

# OS files
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# VS Code / editor
.vscode/
.idea/

# Hyper-V disk images and ISOs
*.tmp
*.vhd
*.vhdx
*.iso

# PowerShell transcript files (generated by Start-Transcript)
# logs/ already covers this but keeping explicit
Transcript*.txt
